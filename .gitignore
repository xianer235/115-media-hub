# 忽略日志
logs/
*.log

# 忽略缓存
__pycache__/
*.pyc

# 忽略数据/临时文件
strm/

# 忽略敏感配置 (如果 config 目录下全是私密信息)
# 如果只想忽略特定文件，可以写 config/auth.json 等
config/

.codex/
.cursor/
.codex-ui-check/

# preview runtime (keep scripts, ignore generated/runtime artifacts)
preview-runtime/node_modules/
preview-runtime/.npm-cache/
preview-runtime/shots/
preview-runtime/preview-runtime/

# macOS Finder metadata
.DS_Store
**/.DS_Store
